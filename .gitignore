# Local Python environment
.venv/
venv/
__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Local secrets and machine-specific config
.env
.env.*
!.env.example
config.yaml
config.local.yaml

# Runtime RAG data and generated artifacts
data/*
!data/.gitkeep
!data/README.md
logs/*
!logs/.gitkeep
!logs/README.md
vector_db/*
watched_folder/*
