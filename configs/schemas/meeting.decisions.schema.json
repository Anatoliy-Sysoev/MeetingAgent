{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://meetingagent.local/schemas/meeting.decisions.schema.json",
  "title": "MeetingAgent decisions.json",
  "description": "Структурированные решения, извлеченные из встречи. Каждый пункт должен ссылаться на фрагмент transcript или иной проверяемый источник.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "meeting_id",
    "generated_at",
    "items"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "meeting_id": {
      "$ref": "#/$defs/meeting_id"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "items": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/decision"
      }
    }
  },
  "$defs": {
    "meeting_id": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}__[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision_id",
        "title",
        "decision",
        "status",
        "source_refs"
      ],
      "properties": {
        "decision_id": {
          "type": "string",
          "pattern": "^DEC-\\d{3}$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "decision": {
          "type": "string",
          "minLength": 1
        },
        "rationale": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "proposed",
            "accepted",
            "rejected",
            "superseded"
          ]
        },
        "owner": {
          "type": "string"
        },
        "due_date": {
          "type": "string",
          "format": "date"
        },
        "source_refs": {
          "$ref": "#/$defs/source_refs"
        },
        "needs_review": {
          "type": "boolean"
        }
      }
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/source_ref"
      }
    },
    "source_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "path"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "transcript_segment",
            "rag_source",
            "manual_note"
          ]
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "segment_index": {
          "type": "integer",
          "minimum": 0
        },
        "start": {
          "type": "number",
          "minimum": 0
        },
        "end": {
          "type": "number",
          "minimum": 0
        },
        "quote": {
          "type": "string",
          "maxLength": 500
        },
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    }
  }
}
