{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://meetingagent.local/schemas/meeting.risks.schema.json",
  "title": "MeetingAgent risks.json",
  "description": "Риски, ограничения и потенциальные проблемы, извлеченные из встречи.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "meeting_id",
    "generated_at",
    "items"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "meeting_id": {
      "$ref": "#/$defs/meeting_id"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "items": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/risk"
      }
    }
  },
  "$defs": {
    "meeting_id": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}__[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "risk_id",
        "title",
        "description",
        "impact",
        "probability",
        "status",
        "source_refs"
      ],
      "properties": {
        "risk_id": {
          "type": "string",
          "pattern": "^RISK-\\d{3}$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "impact": {
          "$ref": "#/$defs/level"
        },
        "probability": {
          "$ref": "#/$defs/level"
        },
        "mitigation": {
          "type": "string"
        },
        "owner": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "open",
            "monitoring",
            "mitigated",
            "closed"
          ]
        },
        "source_refs": {
          "$ref": "#/$defs/source_refs"
        },
        "needs_review": {
          "type": "boolean"
        }
      }
    },
    "level": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/source_ref"
      }
    },
    "source_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "path"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "transcript_segment",
            "rag_source",
            "manual_note"
          ]
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "segment_index": {
          "type": "integer",
          "minimum": 0
        },
        "start": {
          "type": "number",
          "minimum": 0
        },
        "end": {
          "type": "number",
          "minimum": 0
        },
        "quote": {
          "type": "string",
          "maxLength": 500
        },
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    }
  }
}
