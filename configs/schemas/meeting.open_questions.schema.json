{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://meetingagent.local/schemas/meeting.open_questions.schema.json",
  "title": "MeetingAgent open_questions.json",
  "description": "Открытые вопросы встречи, которые требуют уточнения, ответа или отдельного follow-up.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "meeting_id",
    "generated_at",
    "items"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "meeting_id": {
      "$ref": "#/$defs/meeting_id"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "items": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/open_question"
      }
    }
  },
  "$defs": {
    "meeting_id": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}__[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "open_question": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "question_id",
        "question",
        "status",
        "source_refs"
      ],
      "properties": {
        "question_id": {
          "type": "string",
          "pattern": "^Q-\\d{3}$"
        },
        "question": {
          "type": "string",
          "minLength": 1
        },
        "context": {
          "type": "string"
        },
        "owner": {
          "type": "string"
        },
        "due_date": {
          "type": "string",
          "format": "date"
        },
        "status": {
          "type": "string",
          "enum": [
            "open",
            "answered",
            "closed"
          ]
        },
        "answer": {
          "type": "string"
        },
        "source_refs": {
          "$ref": "#/$defs/source_refs"
        },
        "needs_review": {
          "type": "boolean"
        }
      }
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/source_ref"
      }
    },
    "source_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "path"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "transcript_segment",
            "rag_source",
            "manual_note"
          ]
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "segment_index": {
          "type": "integer",
          "minimum": 0
        },
        "start": {
          "type": "number",
          "minimum": 0
        },
        "end": {
          "type": "number",
          "minimum": 0
        },
        "quote": {
          "type": "string",
          "maxLength": 500
        },
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    }
  }
}
