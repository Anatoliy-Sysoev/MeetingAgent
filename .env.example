# Copy to .env only if a future service needs environment variables.
# Do not commit .env.

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_KEEP_ALIVE=24h
OLLAMA_NUM_PARALLEL=1

MEETING_AGENT_WORK_ROOT=%USERPROFILE%/Desktop/AI/MeetingAgent
