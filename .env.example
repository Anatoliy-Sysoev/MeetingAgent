# Скопируй в .env только если будущему сервису понадобятся переменные окружения.
# .env нельзя коммитить.
# Не коммить реальные токены, пароли и локальные секреты.

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_KEEP_ALIVE=24h
OLLAMA_NUM_PARALLEL=1

MEETING_AGENT_WORK_ROOT=%USERPROFILE%/Desktop/AI/MeetingAgent
MEETING_AGENT_PROJECT_ROOT=%USERPROFILE%/Desktop/PROJECT_DOCUMENTS

MEETING_AGENT_EMBEDDING_MODEL=bge-m3
MEETING_AGENT_CHAT_MODEL=qwen2.5:7b-instruct
MEETING_AGENT_EMBEDDING_NUM_CTX=8192

# Project Knowledge Bot / Telegram adapter
ASU_JUNE_BOT_TELEGRAM_TOKEN=PASTE_TOKEN_HERE
ASU_JUNE_BOT_CHAT_API_URL=http://127.0.0.1:8000/chat
ASU_JUNE_BOT_ALLOWED_CHAT_IDS=123456789
ASU_JUNE_BOT_TELEGRAM_TOP_K=5
ASU_JUNE_BOT_TELEGRAM_MODEL=qwen2.5:7b-instruct
ASU_JUNE_BOT_TELEGRAM_MAX_TOKENS=700
ASU_JUNE_BOT_TELEGRAM_TIMEOUT_SEC=300
